    <div class="sys-left reveal">
      <div class="section-label">02 — Under the Hood</div>
      <h2>Systems that<br><span class="outline">Explain</span><br>Themselves.</h2>

      <div class="code-block">
        <div class="code-bar">
          <span class="code-file">packages/auth/verify.ts</span>
          <span class="code-lang">TypeScript</span>
        </div>
        <div class="code-body"><pre><span class="c">// Full JWKS JWT verification — jose</span>
<span class="k">import</span> &lbrace; jwtVerify, createRemoteJWKSet &rbrace;
  <span class="k">from</span> <span class="s">"jose"</span>;

<span class="k">export async function</span> <span class="f">verifyAccess</span>(
  req: Request, env: <span class="t">AccessEnv</span>
): <span class="t">Promise</span>&lt;<span class="t">VerifyResult</span>&gt; &lbrace;
  <span class="k">if</span> (!env.CLOUDFLARE_ACCESS_AUDIENCE)
    <span class="k">return</span> &lbrace; authorized: <span class="n">false</span> &rbrace;;

  <span class="k">const</span> JWKS = createRemoteJWKSet(
    <span class="k">new</span> URL(
      <span class="s">`&#36;&lbrace;</span>env.CF_ACCESS_TEAM_DOMAIN<span class="s">&rbrace;
      /cdn-cgi/access/certs`</span>
    )
  );
  <span class="k">const</span> &lbrace; payload &rbrace; = <span class="k">await</span>
    <span class="f">jwtVerify</span>(token, JWKS, &lbrace;
      issuer:   env.CF_ACCESS_TEAM_DOMAIN,
      audience: env.CLOUDFLARE_ACCESS_AUDIENCE
    &rbrace;);
  <span class="k">return</span> &lbrace; authorized: <span class="n">true</span>,
             email: payload.email &rbrace;;
&rbrace;</pre></div>
      </div>
    </div>

